{
    "layer": "top",
    "position": "top",
    "width": 1920,
    "margin": "5 0",

    "group/left": {
        "orientation": "horizontal",
        "modules": ["hyprland/workspaces"]
    },

    "group/right": {
        "orientation": "horizontal",
        "modules": ["network", "battery", "clock", "pulseaudio"]
    },

    "modules-left": ["group/left"],
    "modules-center": [],
    "modules-right": ["group/right"],

    "include": ["~/.config/waybar/modules.jsonc"]
}
